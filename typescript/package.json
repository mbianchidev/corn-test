{
  "name": "corn-test-typescript",
  "version": "1.0.0",
  "description": "Sample TypeScript app with flaky tests for testing purposes",
  "scripts": {
    "build": "tsc",
    "test:jest": "jest --ci --reporters=default --reporters=jest-junit",
    "test:playwright": "playwright test",
    "test": "npm run test:jest && npm run test:playwright"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "jest-junit": "^16.0.0",
    "@playwright/test": "^1.42.0"
  }
}
