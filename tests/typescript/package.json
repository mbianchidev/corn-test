{
  "name": "corn-test-typescript",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript tests with Vitest and Jest (ts-jest) for flakiness detection",
  "scripts": {
    "test:vitest": "vitest run --reporter=junit --outputFile=./vitest-results/junit.xml",
    "test:jest": "jest --ci --reporters=default --reporters=jest-junit"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "typescript": "^5.7.0",
    "ts-jest": "^29.2.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "@types/jest": "^29.5.0"
  },
  "jest-junit": {
    "outputDirectory": "./jest-results",
    "outputName": "junit.xml"
  }
}
